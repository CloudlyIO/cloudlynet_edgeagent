# CloudlyNet Edge Agent runtime environment (installed to /etc/cloudlynet-agent/agent.env).
# This file is read by systemd via EnvironmentFile; keep it mode 0600.

# REQUIRED: enrollment token issued by the NanoLink dashboard for this edge.
CLOUDLYNET_ENROLLMENT_TOKEN=

# Optional: override the base_url embedded in the token (e.g. for staging or an
# older token that still points at http://localhost:8080).
#CLOUDLYNET_BASE_URL=https://netai.cloudly.io/

# Local GenieACS NBI on this edge box.
GENIEACS_NBI_URL=http://127.0.0.1:7557

# NanoLink FTP log-drop directory the agent watches for .tgz archives.
FTP_WATCH_DIR=/srv/nybsys-ftp/nybsysftp/uploads

# SQLite telemetry outbox / command-dedupe store (local file, not a service).
BUFFER_DB=/var/lib/cloudlynet-agent/buffer.sqlite
